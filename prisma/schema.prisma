// This is your Prisma schema file,
// learn more about it in the docs: https://pris.ly/d/prisma-schema

generator client {
  provider = "prisma-client-js"
  output   = "../src/generated"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

// User model - Admin, Manager, User roles
model User {
  id       String   @id @default(cuid())
  email    String   @unique
  password String
  phone    String?
  fullName String
  role     UserRole @default(USER)

  // Relations
  vehicles       Vehicle[]
  bookings       Booking[]
  payments       Payment[]
  monthlyPasses  MonthlyPass[]
  parkingRecords ParkingRecord[]

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

enum UserRole {
  ADMIN
  USER
}

// Vehicle model - stores customer's vehicles
model Vehicle {
  id          String      @id @default(cuid())
  userId      String
  plateNumber String      @unique
  vehicleType VehicleType
  color       String?

  // Relations
  user           User            @relation(fields: [userId], references: [id], onDelete: Cascade)
  bookings       Booking[]
  parkingRecords ParkingRecord[]

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([userId])
}

enum VehicleType {
  CAR
  MOTORBIKE
}

// ParkingLot model - parking facility information
model ParkingLot {
  id                  String   @id @default(cuid())
  name                String
  address             String
  totalSlots          Int
  lotType             LotType  @default(BOTH)
  zones               Json? // stores zone configuration: { carZones: [...], motoZones: [...] }
  carHourlyRate       Decimal? @db.Decimal(10, 2)
  motorbikeHourlyRate Decimal? @db.Decimal(10, 2)

  // Relations
  slots          ParkingSlot[]
  bookings       Booking[]
  parkingRecords ParkingRecord[]

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

enum LotType {
  CAR_ONLY
  MOTORBIKE_ONLY
  BOTH
}

// ParkingSlot model - individual parking spaces
model ParkingSlot {
  id           String      @id @default(cuid())
  parkingLotId String
  zoneId       String
  slotNumber   String
  vehicleType  VehicleType
  status       SlotStatus  @default(AVAILABLE)

  // Relations
  parkingLot     ParkingLot      @relation(fields: [parkingLotId], references: [id], onDelete: Cascade)
  bookings       Booking[]
  parkingRecords ParkingRecord[]

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@unique([parkingLotId, slotNumber])
  @@index([parkingLotId])
  @@index([status])
}

enum SlotStatus {
  AVAILABLE
  OCCUPIED
  RESERVED
  MAINTENANCE
}

// Booking model - customer parking reservations
model Booking {
  id            String        @id @default(cuid())
  userId        String
  vehicleId     String
  parkingSlotId String
  parkingLotId  String
  startTime     DateTime
  endTime       DateTime
  estimatedCost Decimal       @db.Decimal(10, 2)
  status        BookingStatus @default(PENDING_PAYMENT)

  // Relations
  user          User           @relation(fields: [userId], references: [id], onDelete: Cascade)
  vehicle       Vehicle        @relation(fields: [vehicleId], references: [id], onDelete: Cascade)
  parkingSlot   ParkingSlot    @relation(fields: [parkingSlotId], references: [id], onDelete: Cascade)
  parkingLot    ParkingLot     @relation(fields: [parkingLotId], references: [id], onDelete: Cascade)
  payment       Payment?
  parkingRecord ParkingRecord? @relation(fields: [parkingRecordId], references: [id])

  createdAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt
  parkingRecordId String?

  @@index([userId])
  @@index([vehicleId])
  @@index([parkingSlotId])
  @@index([status])
}

enum BookingStatus {
  PENDING_PAYMENT // waiting for payment
  CONFIRMED // slot is reserved
  COMPLETED // parking finished
  CANCELLED // cancelled by user
}

// ParkingRecord model - actual vehicle entry/exit logs
model ParkingRecord {
  id            String              @id @default(cuid())
  userId        String
  vehicleId     String
  parkingLotId  String
  parkingSlotId String
  bookingId     String?
  checkInTime   DateTime
  checkOutTime  DateTime?
  actualCost    Decimal             @default(0) @db.Decimal(10, 2)
  paymentStatus PaymentStatus       @default(PENDING)
  status        ParkingRecordStatus @default(CHECKED_IN)

  // Relations
  user        User        @relation(fields: [userId], references: [id], onDelete: Cascade)
  vehicle     Vehicle     @relation(fields: [vehicleId], references: [id], onDelete: Cascade)
  parkingLot  ParkingLot  @relation(fields: [parkingLotId], references: [id], onDelete: Cascade)
  parkingSlot ParkingSlot @relation(fields: [parkingSlotId], references: [id], onDelete: Cascade)

  createdAt DateTime  @default(now())
  updatedAt DateTime  @updatedAt
  bookings  Booking[]
  payment   Payment?
  monthlyPass MonthlyPass? @relation(fields: [monthlyPassId], references: [id])
  monthlyPassId String?

  @@index([userId])
  @@index([vehicleId])
  @@index([parkingLotId])
  @@index([checkInTime])
}

enum ParkingRecordStatus {
  CHECKED_IN
  CHECKED_OUT
}

// Payment model - payment transactions
model Payment {
  id              String        @id @default(cuid())
  userId          String
  bookingId       String?       @unique
  monthlyPassId   String?       @unique
  parkingRecordId String?       @unique
  amount          Decimal       @db.Decimal(10, 2)
  method          PaymentMethod
  status          PaymentStatus @default(PENDING)
  referenceId     String? // transaction ID from payment gateway

  // Relations
  user          User           @relation(fields: [userId], references: [id], onDelete: Cascade)
  booking       Booking?       @relation(fields: [bookingId], references: [id], onDelete: SetNull)
  monthlyPass   MonthlyPass?   @relation(fields: [monthlyPassId], references: [id], onDelete: SetNull)
  parkingRecord ParkingRecord? @relation(fields: [parkingRecordId], references: [id], onDelete: SetNull)

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([userId])
  @@index([status])
}

enum PaymentMethod {
  CASH
  VNPAY
}

enum PaymentStatus {
  PENDING
  SUCCESS
  FAILED
  REFUNDED
}

// MonthlyPass model - monthly parking subscription
model MonthlyPass {
  id          String      @id @default(cuid())
  userId      String
  vehicleType VehicleType
  startDate   DateTime
  endDate     DateTime
  price       Decimal     @db.Decimal(10, 2)
  status      PassStatus  @default(ACTIVE)

  // Relations
  user           User            @relation(fields: [userId], references: [id], onDelete: Cascade)
  payment        Payment?
  parkingRecords ParkingRecord[]

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([userId])
  @@index([status])
}

enum PassStatus {
  ACTIVE
  EXPIRED
  CANCELLED
}

